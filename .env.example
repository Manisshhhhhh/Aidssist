# Gemini Flash for code generation, analysis, summaries, and research-backed outputs
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
AIDSSIST_ENV=development
AIDSSIST_API_HOST=0.0.0.0
AIDSSIST_API_PORT=8000
AIDSSIST_CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
AIDSSIST_EMBEDDING_MODEL=text-embedding-004
AIDSSIST_EMBEDDING_DIMENSIONS=128
AIDSSIST_CHUNK_SIZE_CHARS=1400
AIDSSIST_CHUNK_OVERLAP_CHARS=160
AIDSSIST_RETRIEVAL_TOP_K=8
AIDSSIST_MAX_SOLVER_RETRIES=2
AIDSSIST_MAX_UPLOAD_MB=500
AIDSSIST_DATABASE_URL=postgresql+psycopg://aidssist:aidssist@postgres:5432/aidssist
AIDSSIST_REDIS_URL=redis://redis:6379/0
AIDSSIST_API_URL=http://fastapi-api:8000
AIDSSIST_S3_ENDPOINT_URL=http://minio:9000
AIDSSIST_S3_ACCESS_KEY_ID=minioadmin
AIDSSIST_S3_SECRET_ACCESS_KEY=minioadmin
AIDSSIST_S3_BUCKET_NAME=aidssist-artifacts
AIDSSIST_OBJECT_STORE_BACKEND=minio
AIDSSIST_PROVIDER_MAX_CONCURRENCY=4
AIDSSIST_DB_POOL_SIZE=20
AIDSSIST_DB_MAX_OVERFLOW=40
AIDSSIST_SLOW_QUERY_MS=250
AIDSSIST_LOG_LEVEL=INFO

# Simple public demo deployment defaults
# AIDSSIST_OBJECT_STORE_BACKEND=local
# AIDSSIST_REDIS_URL=
# AIDSSIST_DATABASE_URL=
# AIDSSIST_API_URL=https://your-backend.onrender.com
